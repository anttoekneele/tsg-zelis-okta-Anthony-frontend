@page "/roles/assign"
@rendermode InteractiveServer
@inject GraphQLService graphQLService

<h2>Assign User Role</h2>

<div class="form-group">
    <label>User</label>
    <select @bind="SelectedUserId" class="form-control">
        <option value="">-- Select User --</option>
        @foreach (var user in Users)
        {
            <option value="@user.Id.ToString()">@user.Email</option>
        }
    </select>
</div>

<div class="form-group">
    <label>Role</label>
    <select @bind="SelectedRoleId" class="form-control">
        <option value="">-- Select Role --</option>
        @foreach (var role in Roles)
        {
            <option value="@role.Id.ToString()">@role.Name</option>
        }
    </select>
</div>

<button class="btn btn-success" @onclick="AssignRole">Save</button>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p class="text-success">@Message</p>
}

@code {
    private List<User> Users = new();
    private List<Role> Roles = new();
    private Guid SelectedUserId;
    private Guid SelectedRoleId;
    private string Message;

    protected override async Task OnInitializedAsync()
    {
        Users = await graphQLService.GetUsers();
        Roles = await graphQLService.GetRoles();
    }

    private async Task AssignRole()
    {
        if (SelectedUserId == Guid.Empty || SelectedRoleId == Guid.Empty)
        {
            Message = "❌ Please select both a user and a role.";
            return;
        }

        var success = await graphQLService.AssignUserRole(SelectedUserId, SelectedRoleId);

        if (success)
        {
            Message = "✅ Role assigned successfully!";
        }
        else
        {
            Message = "⚠️ No changes made. User already has this role.";
        }
    }
}
