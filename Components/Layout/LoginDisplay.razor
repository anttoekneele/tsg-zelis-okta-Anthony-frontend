<AuthorizeView>
    <Authorized>
        <a href="#">Hello, @context.User.Identity.Name!</a>
        <a href="/signout">Sign out</a>
    </Authorized>
    <NotAuthorized>
        <a href="/signin/okta">Sign in with Okta</a>
        <a href="/signin/google">Sign in with Google</a>
    </NotAuthorized>
</AuthorizeView>